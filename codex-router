#!/usr/bin/env bash
set -euo pipefail

personal_context="personal"
work_context="work"
personal_home="$HOME/.codex-personal"
work_home="$HOME/.codex-work"
work_patterns="$HOME/src/work:$HOME/src/work/*:$HOME/Documents/code/codapt*:$HOME/Documents/code/niels-mac-pi-kvm*"
real_codex="$HOME/.local/bin/codex"

fail() {
  printf '%s\n' "$*" >&2
  exit 1
}

canonical_path() {
  local target="$1"
  local dir
  local base

  if command -v realpath >/dev/null 2>&1; then
    realpath "$target" 2>/dev/null && return
  fi

  dir="$(dirname "$target")"
  base="$(basename "$target")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
  else
    printf '%s\n' "$target"
  fi
}

resolve_path() {
  local target="${1:-$PWD}"
  local dir
  local base

  if [[ "$target" != /* ]]; then
    target="$PWD/$target"
  fi

  if [[ -d "$target" ]]; then
    (cd "$target" && pwd -P)
    return
  fi

  dir="$(dirname "$target")"
  base="$(basename "$target")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
  else
    printf '%s\n' "$target"
  fi
}

codex_target_from_args() {
  local target="$PWD"
  local arg
  local next_is_cd=0

  for arg in "$@"; do
    if (( next_is_cd )); then
      target="$arg"
      next_is_cd=0
      continue
    fi

    case "$arg" in
      -C|--cd)
        next_is_cd=1
        ;;
      --cd=*)
        target="${arg#--cd=}"
        ;;
    esac
  done

  printf '%s\n' "$target"
}

context_for_path() {
  local target
  local pattern
  local old_ifs
  local patterns

  target="$(resolve_path "${1:-$PWD}")"

  old_ifs="$IFS"
  IFS=:
  read -r -a patterns <<< "$work_patterns"
  IFS="$old_ifs"

  for pattern in "${patterns[@]}"; do
    [[ -n "$pattern" ]] || continue
    # shellcheck disable=SC2053
    if [[ "$target" == $pattern ]]; then
      printf '%s\n' "$work_context"
      return
    fi
  done

  printf '%s\n' "$personal_context"
}

context_from_command() {
  case "$(basename "$0")" in
    codex-personal) printf '%s\n' "$personal_context" ;;
    codex-work) printf '%s\n' "$work_context" ;;
    *) return 1 ;;
  esac
}

home_for_context() {
  case "$1" in
    "$personal_context") printf '%s\n' "$personal_home" ;;
    "$work_context") printf '%s\n' "$work_home" ;;
    *) fail "Unsupported AI_CONTEXT '$1' (expected $personal_context or $work_context)" ;;
  esac
}

select_context() {
  local target

  if context_from_command; then
    return
  fi

  case "${AI_CONTEXT:-}" in
    "$personal_context"|"$work_context")
      printf '%s\n' "$AI_CONTEXT"
      return
      ;;
    "")
      ;;
    *)
      fail "Unsupported AI_CONTEXT '$AI_CONTEXT' (expected $personal_context or $work_context)"
      ;;
  esac

  target="$(codex_target_from_args "$@")"
  context_for_path "$target"
}

router_path="$(canonical_path "$HOME/.local/libexec/codex-router")"
real_path="$(canonical_path "$real_codex")"
if [[ "$real_path" == "$router_path" ]]; then
  fail "Codex binary resolves to the router itself: $real_codex"
fi

if [[ ! -x "$real_codex" ]]; then
  fail "Codex binary not executable: $real_codex"
fi

if [[ "${CODEX_ROUTER_PRINT_BIN:-}" == "1" ]]; then
  printf '%s\n' "$real_codex"
  exit 0
fi

context="$(select_context "$@")"
codex_home="$(home_for_context "$context")"

if [[ "${CODEX_ROUTER_PRINT_CONTEXT:-}" == "1" ]]; then
  printf '%s\n' "$context"
  exit 0
fi

if [[ "${CODEX_ROUTER_PRINT_HOME:-}" == "1" ]]; then
  printf '%s\n' "$codex_home"
  exit 0
fi

if [[ ! -d "$codex_home" ]]; then
  fail "Codex home does not exist: $codex_home"
fi

export CODEX_HOME="$codex_home"
exec "$real_codex" "$@"
