# Managed Zsh interactive helpers for the dev box.

if command -v eza >/dev/null 2>&1; then
  alias ls='eza'
  alias ll='eza -lah --git --group-directories-first'
  alias tree='eza --tree'
else
  alias ll='ls -lah'
fi

if command -v bat >/dev/null 2>&1; then
  alias catp='bat'
fi

if command -v lazygit >/dev/null 2>&1; then
  alias lg='lazygit'
fi

if command -v yazi >/dev/null 2>&1; then
  alias y='yazi'
fi

alias gs='git status --short --branch'
alias t='tmux new -A -s main'
alias work='cd ~/src/work'
alias personal='cd ~/src/personal'
alias dps='docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'

# Later entries are prepended, so command shortcuts in ~/bin win over package
# manager binaries in ~/.local/bin while npm still owns the real executables.
for _devbox_path_dir in "$HOME/.local/share/mise/shims" "$HOME/.local/bin" "$HOME/bin"; do
  case ":$PATH:" in
    *":$_devbox_path_dir:"*) ;;
    *) export PATH="$_devbox_path_dir:$PATH" ;;
  esac
done
unset _devbox_path_dir

# Directory-aware AI account routing.
#
# The state directory is the auth/config/history boundary. Command files in
# ~/bin are symlinks to routers under ~/.local/libexec; npm owns the real
# binaries under ~/.local/bin.
_ai_codex_router() {
  local router="$HOME/bin/codex"

  [[ -x "$router" ]] || return 1
  printf '%s\n' "$router"
}

_ai_claude_router() {
  local router="$HOME/bin/claude"

  [[ -x "$router" ]] || return 1
  printf '%s\n' "$router"
}

ai-context() {
  CODEX_ROUTER_PRINT_CONTEXT=1 "$(_ai_codex_router)" "$@"
}

codex-home() {
  CODEX_ROUTER_PRINT_HOME=1 "$(_ai_codex_router)" "$@"
}

codex-bin() {
  CODEX_ROUTER_PRINT_BIN=1 "$(_ai_codex_router)" "$@"
}

claude-home() {
  CLAUDE_ROUTER_PRINT_HOME=1 "$(_ai_claude_router)" "$@"
}

claude-bin() {
  CLAUDE_ROUTER_PRINT_BIN=1 "$(_ai_claude_router)" "$@"
}

ai-whoami() {
  local context
  local codex_bin
  local codex_home
  local claude_bin
  local claude_dir

  context="$(ai-context)"
  codex_bin="$(codex-bin 2>/dev/null || true)"
  codex_home="$(codex-home)"
  claude_bin="$(claude-bin 2>/dev/null || true)"
  claude_dir="$(claude-home)"

  printf 'cwd: %s\n' "$PWD"
  printf 'context: %s\n' "$context"
  printf 'codex binary: %s\n' "${codex_bin:-missing}"
  printf 'codex home: %s\n' "$codex_home"
  if [[ -n "$codex_bin" ]]; then
    CODEX_HOME="$codex_home" "$codex_bin" login status 2>&1 | sed 's/^/codex status: /'
  else
    printf 'codex status: binary missing\n'
  fi
  printf 'claude binary: %s\n' "${claude_bin:-missing}"
  printf 'claude config: %s\n' "$claude_dir"
  if [[ -n "$claude_bin" ]]; then
    CLAUDE_CONFIG_DIR="$claude_dir" "$claude_bin" auth status 2>&1 | sed 's/^/claude status: /'
  else
    printf 'claude status: binary missing\n'
  fi
}
