#!/usr/bin/env bash
set -euo pipefail

personal_context="personal"
work_context="work"
work_patterns="${AI_WORK_PATTERNS:-}"

fail() {
  printf '%s\n' "$*" >&2
  exit 1
}

canonical_path() {
  local target="$1"
  local dir
  local base

  if command -v realpath >/dev/null 2>&1; then
    realpath "$target" 2>/dev/null && return
  fi

  dir="$(dirname "$target")"
  base="$(basename "$target")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
  else
    printf '%s\n' "$target"
  fi
}

resolve_path() {
  local target="${1:-$PWD}"
  local dir
  local base

  if [[ "$target" != /* ]]; then
    target="$PWD/$target"
  fi

  if [[ -d "$target" ]]; then
    (cd "$target" && pwd -P)
    return
  fi

  dir="$(dirname "$target")"
  base="$(basename "$target")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
  else
    printf '%s\n' "$target"
  fi
}

if [[ -z "$work_patterns" ]]; then
  home_physical="$(canonical_path "$HOME")"
  work_patterns="$HOME/src/work:$HOME/src/work/*:$HOME/Documents/code/codapt*:$HOME/Documents/code/niels-mac-pi-kvm*"
  if [[ "$home_physical" != "$HOME" ]]; then
    work_patterns+=":$home_physical/src/work:$home_physical/src/work/*:$home_physical/Documents/code/codapt*:$home_physical/Documents/code/niels-mac-pi-kvm*"
  fi
  unset home_physical
fi

tool_from_command() {
  case "$(basename "$0")" in
    codex|codex-personal|codex-work) printf 'codex\n' ;;
    claude|claude-personal|claude-work) printf 'claude\n' ;;
    *) fail "Unsupported AI router command name: $(basename "$0")" ;;
  esac
}

target_from_args() {
  local target="$PWD"
  local arg
  local next_is_cd=0

  for arg in "$@"; do
    if (( next_is_cd )); then
      target="$arg"
      next_is_cd=0
      continue
    fi

    case "$arg" in
      -C|--cd)
        next_is_cd=1
        ;;
      --cd=*)
        target="${arg#--cd=}"
        ;;
    esac
  done

  printf '%s\n' "$target"
}

context_for_path() {
  local target
  local pattern
  local old_ifs
  local patterns

  target="$(resolve_path "${1:-$PWD}")"

  old_ifs="$IFS"
  IFS=:
  read -r -a patterns <<< "$work_patterns"
  IFS="$old_ifs"

  for pattern in "${patterns[@]}"; do
    [[ -n "$pattern" ]] || continue
    # shellcheck disable=SC2053
    if [[ "$target" == $pattern ]]; then
      printf '%s\n' "$work_context"
      return
    fi
  done

  printf '%s\n' "$personal_context"
}

context_from_command() {
  case "$(basename "$0")" in
    *-personal) printf '%s\n' "$personal_context" ;;
    *-work) printf '%s\n' "$work_context" ;;
    *) return 1 ;;
  esac
}

select_context() {
  local target

  if context_from_command; then
    return
  fi

  case "${AI_CONTEXT:-}" in
    "$personal_context"|"$work_context")
      printf '%s\n' "$AI_CONTEXT"
      return
      ;;
    "")
      ;;
    *)
      fail "Unsupported AI_CONTEXT '$AI_CONTEXT' (expected $personal_context or $work_context)"
      ;;
  esac

  target="$(target_from_args "$@")"
  context_for_path "$target"
}

state_dir_for_context() {
  local tool="$1"
  local context="$2"

  case "$tool:$context" in
    codex:personal) printf '%s\n' "$HOME/.codex-personal" ;;
    codex:work) printf '%s\n' "$HOME/.codex-work" ;;
    claude:personal) printf '%s\n' "$HOME/.claude-personal" ;;
    claude:work) printf '%s\n' "$HOME/.claude-work" ;;
    *) fail "Unsupported AI context: $tool/$context" ;;
  esac
}

print_env_prefix() {
  case "$1" in
    codex) printf 'CODEX_ROUTER' ;;
    claude) printf 'CLAUDE_ROUTER' ;;
    *) fail "Unsupported AI tool: $1" ;;
  esac
}

tool="$(tool_from_command)"
real_binary="$HOME/.local/bin/$tool"
router_path="$(canonical_path "$HOME/.local/libexec/ai-router")"
real_path="$(canonical_path "$real_binary")"
env_prefix="$(print_env_prefix "$tool")"
print_bin_var="${env_prefix}_PRINT_BIN"
print_context_var="${env_prefix}_PRINT_CONTEXT"
print_home_var="${env_prefix}_PRINT_HOME"

if [[ "$real_path" == "$router_path" ]]; then
  fail "$tool binary resolves to the router itself: $real_binary"
fi

if [[ ! -x "$real_binary" ]]; then
  fail "$tool binary not executable: $real_binary"
fi

if [[ "${!print_bin_var:-}" == "1" ]]; then
  printf '%s\n' "$real_binary"
  exit 0
fi

context="$(select_context "$@")"
state_dir="$(state_dir_for_context "$tool" "$context")"

if [[ "${!print_context_var:-}" == "1" ]]; then
  printf '%s\n' "$context"
  exit 0
fi

if [[ "${!print_home_var:-}" == "1" ]]; then
  printf '%s\n' "$state_dir"
  exit 0
fi

if [[ ! -d "$state_dir" ]]; then
  fail "$tool state directory does not exist: $state_dir"
fi

case "$tool" in
  codex)
    export CODEX_HOME="$state_dir"
    ;;
  claude)
    export CLAUDE_CONFIG_DIR="$state_dir"
    ;;
esac

exec "$real_binary" "$@"
