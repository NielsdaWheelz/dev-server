#!/usr/bin/env bash
set -euo pipefail

base_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

server_name="${DEVBOX_SERVER_NAME:-dev-server}"
server_type="${DEVBOX_SERVER_TYPE:-cpx21}"
server_image="${DEVBOX_SERVER_IMAGE:-ubuntu-24.04}"
server_image_architecture="${DEVBOX_SERVER_IMAGE_ARCHITECTURE:-x86}"
server_location="${DEVBOX_SERVER_LOCATION:-hil}"
hcloud_context="${DEVBOX_HCLOUD_CONTEXT:-dev-infra}"
ssh_key_name="${DEVBOX_HCLOUD_SSH_KEY:-niels-macbook}"
firewall_name="${DEVBOX_FIREWALL:-dev-server-private}"
server_user="${DEVBOX_USER:-niels}"
ssh_identity="${DEVBOX_SSH_IDENTITY:-$HOME/.ssh/id_ed25519}"
ssh_config="${DEVBOX_SSH_CONFIG:-$HOME/.ssh/config}"
ssh_include_dir="${DEVBOX_SSH_INCLUDE_DIR:-$HOME/.ssh/config.d}"
ssh_include="${DEVBOX_SSH_INCLUDE:-$ssh_include_dir/$server_name}"
state_file="${DEVBOX_STATE_FILE:-$base_dir/secrets/devbox-state.env}"
tailscale_auth_key_file="${DEVBOX_TAILSCALE_AUTH_KEY_FILE:-$base_dir/secrets/tailscale-auth-key}"
public_web="${DEVBOX_PUBLIC_WEB:-0}"
rootful_docker="${DEVBOX_ROOTFUL_DOCKER:-0}"

template="$base_dir/cloud-init-devbox.template.yaml"
default_output="$base_dir/cloud-init-devbox.yaml"
ansible_inventory="$base_dir/ansible/inventory/devbox.yml"
ansible_converge_playbook="$base_dir/ansible/playbooks/converge.yml"

bootstrap_ssh_description="Temporary bootstrap SSH from operator IPv4"
doctor_failures=0
doctor_warnings=0

log() {
  printf '==> %s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

usage() {
  cat <<EOF
Usage: ./devbox <command>

Commands:
  up        Create or update the VPS, enroll Tailscale, lock down SSH, converge, and doctor.
  rebuild   Delete and recreate the VPS, then run up.
  converge  Run Ansible against the current dev-server SSH alias.
  lockdown  Remove temporary public SSH access.
  doctor    Run a lightweight local and remote smoke check.
  render    Render and validate cloud-init only.

Useful env:
  DEVBOX_TAILSCALE_AUTH_KEY       Short-lived Tailscale auth key for first boot.
  DEVBOX_TAILSCALE_AUTH_KEY_FILE  Defaults to secrets/tailscale-auth-key.
  DEVBOX_BOOTSTRAP_SSH_CIDR       Temporary public SSH CIDR; defaults to current IPv4 /32.
  DEVBOX_PUBLIC_WEB=1             Keep public HTTP/HTTPS open.
  DEVBOX_ROOTFUL_DOCKER=1         Use rootful Docker for existing rootful boxes.
  DEVBOX_SKIP_LOCKDOWN=1          Leave temporary public SSH open after up.
  DEVBOX_SKIP_CONVERGE=1          Skip Ansible after up.
  DEVBOX_SKIP_DOCTOR=1            Skip doctor after up.
  DEVBOX_SKIP_GITHUB_SSH_KEY=1    Do not auto-register the server GitHub public key.
  DEVBOX_CONFIRM_REBUILD=dev-server
EOF
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

is_truthy() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

hcloud_cmd() {
  hcloud --context "$hcloud_context" "$@"
}

run_ansible_playbook() {
  if command -v ansible-playbook >/dev/null 2>&1; then
    ansible-playbook "$@"
  elif command -v uvx >/dev/null 2>&1; then
    uvx --from ansible-core ansible-playbook "$@"
  else
    die "missing ansible-playbook. Install Ansible or install uv for uvx fallback."
  fi
}

load_state() {
  if [[ -f "$state_file" ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
  fi
}

save_state() {
  mkdir -p "$(dirname "$state_file")"
  chmod 700 "$(dirname "$state_file")"
  {
    printf 'STATE_BOOTSTRAP_SSH_CIDR=%q\n' "${1:-}"
    printf 'STATE_PUBLIC_IP=%q\n' "${2:-}"
    printf 'STATE_TAILSCALE_IP=%q\n' "${3:-}"
  } > "$state_file"
  chmod 600 "$state_file"
}

current_public_ipv4() {
  curl -fsS4 https://api.ipify.org
}

validate_ipv4_cidr() {
  [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}/[0-9]{1,2}$ ]]
}

bootstrap_ssh_cidr() {
  local cidr="${DEVBOX_BOOTSTRAP_SSH_CIDR:-}"

  if [[ -z "$cidr" ]]; then
    cidr="$(current_public_ipv4)/32"
  fi

  validate_ipv4_cidr "$cidr" || die "bootstrap SSH CIDR must be IPv4 CIDR, got: $cidr"
  printf '%s\n' "$cidr"
}

lockdown_bootstrap_ssh_cidr() {
  local cidr="${DEVBOX_BOOTSTRAP_SSH_CIDR:-${STATE_BOOTSTRAP_SSH_CIDR:-}}"

  if [[ -z "$cidr" ]]; then
    warn "no saved bootstrap CIDR; falling back to current public IPv4"
    cidr="$(current_public_ipv4)/32"
  fi

  validate_ipv4_cidr "$cidr" || die "bootstrap SSH CIDR must be IPv4 CIDR, got: $cidr"
  printf '%s\n' "$cidr"
}

tailscale_auth_key() {
  local key="${DEVBOX_TAILSCALE_AUTH_KEY:-}"

  if [[ -z "$key" && -f "$tailscale_auth_key_file" ]]; then
    key="$(tr -d '\r\n' < "$tailscale_auth_key_file")"
  fi

  printf '%s' "$key"
}

require_tailscale_auth_key() {
  local key
  key="$(tailscale_auth_key)"

  if [[ -z "$key" ]]; then
    die "missing Tailscale auth key. Export DEVBOX_TAILSCALE_AUTH_KEY or save a short-lived non-ephemeral key to $tailscale_auth_key_file."
  fi
}

base64_string() {
  printf '%s' "$1" | base64 | tr -d '\n'
}

preflight_common() {
  require_cmd ssh
  require_cmd ssh-keygen
  require_cmd curl
  require_cmd awk
  require_cmd base64
}

preflight_render() {
  preflight_common
  require_cmd ruby
  [[ -f "$template" ]] || die "missing required file: $template"
}

preflight_hcloud() {
  require_cmd hcloud
}

preflight_hcloud_create() {
  preflight_hcloud
  hcloud_cmd server-type describe "$server_type" >/dev/null
  hcloud_cmd image describe --architecture "$server_image_architecture" "$server_image" >/dev/null
  hcloud_cmd ssh-key describe "$ssh_key_name" >/dev/null
}

render_cloud_init() {
  local cidr="$1"
  local ts_key="$2"
  local render_output="$3"
  local tailscale_key_b64 public_web_value

  tailscale_key_b64="$(base64_string "$ts_key")"
  if is_truthy "$public_web"; then
    public_web_value=1
  else
    public_web_value=0
  fi

  awk \
    -v tailscale_auth_key="$tailscale_key_b64" \
    -v bootstrap_ssh_cidr="$cidr" \
    -v server_name="$server_name" \
    -v server_user="$server_user" \
    -v public_web="$public_web_value" \
    '{
      gsub("__TAILSCALE_AUTH_KEY_B64__", tailscale_auth_key)
      gsub("__BOOTSTRAP_SSH_CIDR__", bootstrap_ssh_cidr)
      gsub("__SERVER_NAME__", server_name)
      gsub("__SERVER_USER__", server_user)
      gsub("__PUBLIC_WEB__", public_web)
      print
    }' "$template" > "$render_output"

  chmod 600 "$render_output"
  log "rendered $render_output"
  log "bootstrap SSH CIDR: $cidr"
  log "public web: $public_web_value"
  if [[ -n "$ts_key" ]]; then
    log "Tailscale auth key: present"
  else
    warn "Tailscale auth key: missing; first boot will not auto-enroll Tailscale"
  fi
}

validate_rendered_cloud_init() {
  local render_output="$1"
  ruby -e "require 'yaml'; YAML.load_file('$render_output'); puts 'cloud-init yaml ok'"

  if grep -n '__[A-Z0-9_][A-Z0-9_]*__' "$render_output"; then
    die "rendered cloud-init still contains placeholders"
  fi
}

server_exists() {
  hcloud_cmd server describe "$server_name" >/dev/null 2>&1
}

server_public_ip() {
  hcloud_cmd server describe "$server_name" -o 'format={{.PublicNet.IPv4.IP}}'
}

ensure_firewall() {
  local cidr="$1"

  if ! hcloud_cmd firewall describe "$firewall_name" >/dev/null 2>&1; then
    log "creating Hetzner firewall $firewall_name"
    hcloud_cmd firewall create \
      --name "$firewall_name" \
      --label purpose=devbox \
      --label role=devbox
  fi

  add_firewall_rule udp 41641 "Tailscale direct WireGuard" 0.0.0.0/0 ::/0
  if is_truthy "$public_web"; then
    add_firewall_rule tcp 80 "HTTP" 0.0.0.0/0 ::/0
    add_firewall_rule tcp 443 "HTTPS" 0.0.0.0/0 ::/0
  else
    delete_firewall_rule tcp 80 "HTTP" 0.0.0.0/0 ::/0
    delete_firewall_rule tcp 443 "HTTPS" 0.0.0.0/0 ::/0
  fi
  add_firewall_rule tcp 22 "$bootstrap_ssh_description" "$cidr"
}

add_firewall_rule() {
  local protocol="$1"
  local port="$2"
  local description="$3"
  shift 3

  local args output_text source_ip
  args=(firewall add-rule --direction in --protocol "$protocol" --port "$port" --description "$description")
  for source_ip in "$@"; do
    args+=(--source-ips "$source_ip")
  done
  args+=("$firewall_name")

  if output_text="$(hcloud_cmd "${args[@]}" 2>&1)"; then
    log "firewall rule added: $protocol/$port $description"
    return
  fi

  case "$output_text" in
    *already*exists*|*duplicate*)
      log "firewall rule already present: $protocol/$port $description"
      ;;
    *)
      printf '%s\n' "$output_text" >&2
      return 1
      ;;
  esac
}

delete_firewall_rule() {
  local protocol="$1"
  local port="$2"
  local description="$3"
  shift 3

  local args output_text source_ip
  args=(firewall delete-rule --direction in --protocol "$protocol" --port "$port" --description "$description")
  for source_ip in "$@"; do
    args+=(--source-ips "$source_ip")
  done
  args+=("$firewall_name")

  if output_text="$(hcloud_cmd "${args[@]}" 2>&1)"; then
    log "firewall rule deleted: $protocol/$port $description"
    return
  fi

  case "$output_text" in
    *not*found*|*does*not*exist*|*not_exists*)
      log "firewall rule already absent: $protocol/$port $description"
      ;;
    *)
      printf '%s\n' "$output_text" >&2
      return 1
      ;;
  esac
}

create_server_if_needed() {
  local user_data_file="$1"

  if server_exists; then
    log "server already exists: $server_name"
    return
  fi

  log "creating $server_name ($server_type, $server_location)"
  hcloud_cmd server create \
    --name "$server_name" \
    --type "$server_type" \
    --image "$server_image" \
    --location "$server_location" \
    --ssh-key "$ssh_key_name" \
    --firewall "$firewall_name" \
    --label purpose=devbox \
    --label environment=dev \
    --label role=devbox \
    --user-data-from-file "$user_data_file"
}

ensure_ssh_include_enabled() {
  mkdir -p "$ssh_include_dir"
  chmod 700 "$HOME/.ssh" "$ssh_include_dir"
  touch "$ssh_config"
  chmod 600 "$ssh_config"

  local include_pattern="$ssh_include_dir/*"
  if ! grep -Fqx "Include $include_pattern" "$ssh_config"; then
    {
      printf '\n# Managed devbox host includes\n'
      printf 'Include %s\n' "$include_pattern"
    } >> "$ssh_config"
    log "enabled SSH include directory in $ssh_config"
  fi
}

write_ssh_include() {
  local primary_ip="$1"
  local public_ip="${2:-}"

  ensure_ssh_include_enabled

  {
    printf '# Managed by %s. Edits may be overwritten.\n' "$base_dir/devbox"
    printf 'Host %s\n' "$server_name"
    printf '  HostName %s\n' "$primary_ip"
    printf '  User %s\n' "$server_user"
    printf '  IdentityFile %s\n' "$ssh_identity"
    printf '  IdentitiesOnly yes\n'
    printf '  ServerAliveInterval 30\n'
    printf '  ServerAliveCountMax 4\n'
    printf '  StrictHostKeyChecking accept-new\n'
    printf '  ForwardAgent no\n'

    if [[ -n "$public_ip" && "$public_ip" != "$primary_ip" ]]; then
      printf '\nHost %s-public\n' "$server_name"
      printf '  HostName %s\n' "$public_ip"
      printf '  User %s\n' "$server_user"
      printf '  IdentityFile %s\n' "$ssh_identity"
      printf '  IdentitiesOnly yes\n'
      printf '  ServerAliveInterval 30\n'
      printf '  ServerAliveCountMax 4\n'
      printf '  StrictHostKeyChecking accept-new\n'
      printf '  ForwardAgent no\n'
    fi
  } > "$ssh_include"

  chmod 600 "$ssh_include"
  log "wrote SSH include: $ssh_include"
}

remove_known_hosts() {
  local host
  for host in "$@"; do
    [[ -n "$host" ]] || continue
    ssh-keygen -R "$host" >/dev/null 2>&1 || true
  done
}

ssh_devbox() {
  ssh -T -o RequestTTY=no -o BatchMode=yes -o ConnectTimeout=10 "$server_name" "$@"
}

quote_remote_args() {
  local quoted="" arg escaped

  for arg in "$@"; do
    printf -v escaped '%q' "$arg"
    quoted+="$escaped "
  done
  printf '%s' "$quoted"
}

ssh_sudo() {
  local quoted
  quoted="$(quote_remote_args "$@")"
  ssh_devbox "sudo -n -- $quoted"
}

ssh_sudo_sh() {
  [[ $# -eq 1 ]] || die "ssh_sudo_sh expects exactly one shell script argument"
  ssh_sudo bash -o pipefail -lc "$1"
}

remote_user_sh() {
  [[ $# -eq 1 ]] || die "remote_user_sh expects exactly one shell script argument"
  local script_q
  printf -v script_q '%q' "$1"
  ssh_devbox "bash -o pipefail -lc $script_q"
}

ensure_server_github_key_registered() {
  if is_truthy "${DEVBOX_SKIP_GITHUB_SSH_KEY:-0}"; then
    warn "skipping GitHub SSH public key registration because DEVBOX_SKIP_GITHUB_SSH_KEY=1"
    return 0
  fi

  if ! command -v gh >/dev/null 2>&1; then
    warn "gh missing locally; cannot register server GitHub public key"
    return 0
  fi

  if ! gh auth status -h github.com >/dev/null 2>&1; then
    warn "gh is not authenticated for github.com; run gh auth login, then ./devbox converge"
    return 0
  fi

  local pub_key existing_keys key_file key_title add_output
  pub_key="$(ssh_devbox "cat '/home/$server_user/.ssh/id_ed25519_github.pub' 2>/dev/null" || true)"
  if [[ -z "$pub_key" ]]; then
    warn "server GitHub public key is not available yet"
    return 0
  fi

  existing_keys="$(gh api user/keys --jq '.[].key' 2>/dev/null || true)"
  if printf '%s\n' "$existing_keys" | grep -Fxq "$pub_key"; then
    log "server GitHub public key already registered"
    return 0
  fi

  key_file="$(mktemp "${TMPDIR:-/tmp}/devbox-github-key.XXXXXX")"
  chmod 600 "$key_file"
  printf '%s\n' "$pub_key" > "$key_file"
  key_title="${DEVBOX_GITHUB_SSH_KEY_TITLE:-$server_name $(date -u +%Y-%m-%d)}"

  if add_output="$(gh ssh-key add "$key_file" --title "$key_title" 2>&1)"; then
    log "registered server GitHub public key: $key_title"
  else
    [[ -n "$add_output" ]] && printf '%s\n' "$add_output" >&2
    warn "failed to register server GitHub public key; run: ssh $server_name cat ~/.ssh/id_ed25519_github.pub"
  fi
  rm -f "$key_file"
}

wait_for_ssh() {
  local label="$1"
  local _attempt

  log "waiting for SSH ($label)"
  for _attempt in {1..90}; do
    if ssh_devbox 'true' >/dev/null 2>&1; then
      return
    fi
    sleep 5
  done

  die "SSH did not become ready for $server_name"
}

wait_for_cloud_init() {
  log "waiting for cloud-init"
  if ! ssh_sudo cloud-init status --wait; then
    warn "cloud-init failed; last bootstrap output follows"
    ssh_sudo tail -n 200 /var/log/cloud-init-output.log || true
    return 1
  fi

  ssh_devbox 'cat /etc/devbox-bootstrap.log'
}

wait_for_tailscale_ip() {
  local _attempt ip

  log "waiting for Tailscale IPv4"
  for _attempt in {1..60}; do
    ip="$(ssh_devbox 'tailscale ip -4 2>/dev/null | head -n 1' || true)"
    if [[ -n "$ip" ]]; then
      printf '%s\n' "$ip"
      return
    fi
    sleep 5
  done

  die "Tailscale IPv4 did not appear"
}

lockdown_impl() {
  local cidr="$1"
  local public_ip="${2:-}"

  validate_ipv4_cidr "$cidr" || die "cannot delete temporary SSH rule without a valid source CIDR"

  log "running host public SSH lockdown"
  ssh_sudo /usr/local/sbin/devbox-lockdown-public-ssh.sh

  if is_truthy "$public_web"; then
    log "ensuring host public web rules are present"
    ssh_sudo_sh 'ufw allow 80/tcp && ufw allow 443/tcp && ufw reload'
  else
    log "ensuring host public web rules are absent"
    ssh_sudo_sh 'ufw --force delete allow 80/tcp || true; ufw --force delete allow 443/tcp || true; ufw reload'
  fi

  log "removing temporary Hetzner public SSH rule"
  delete_firewall_rule tcp 22 "$bootstrap_ssh_description" "$cidr"

  if is_truthy "$public_web"; then
    add_firewall_rule tcp 80 "HTTP" 0.0.0.0/0 ::/0
    add_firewall_rule tcp 443 "HTTPS" 0.0.0.0/0 ::/0
  else
    delete_firewall_rule tcp 80 "HTTP" 0.0.0.0/0 ::/0
    delete_firewall_rule tcp 443 "HTTPS" 0.0.0.0/0 ::/0
  fi

  if [[ -n "$public_ip" ]]; then
    log "verifying public SSH is closed"
    if ssh \
      -o BatchMode=yes \
      -o ConnectTimeout=5 \
      -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -i "$ssh_identity" \
      "$server_user@$public_ip" true >/dev/null 2>&1; then
      die "public SSH still succeeded for $public_ip"
    fi
    log "public SSH is closed"
  fi
}

cmd_render() {
  preflight_render
  load_state

  local cidr ts_key render_output cleanup_output
  cidr="$(bootstrap_ssh_cidr)"
  ts_key="$(tailscale_auth_key)"

  if [[ -n "${DEVBOX_RENDER_OUTPUT:-}" ]]; then
    render_output="$DEVBOX_RENDER_OUTPUT"
    cleanup_output=0
  else
    render_output="$(mktemp "${TMPDIR:-/tmp}/devbox-cloud-init.XXXXXX")"
    cleanup_output=1
  fi

  if (( cleanup_output )); then
    trap 'rm -f "$render_output"' EXIT
  fi

  render_cloud_init "$cidr" "$ts_key" "$render_output"
  validate_rendered_cloud_init "$render_output"

  if (( cleanup_output )); then
    rm -f "$render_output"
    log "removed temporary rendered cloud-init"
    trap - EXIT
  fi
}

cmd_up() {
  preflight_render
  load_state
  require_tailscale_auth_key
  preflight_hcloud_create

  local cidr ts_key public_ip tailscale_ip render_output server_preexisted
  cidr="$(bootstrap_ssh_cidr)"
  ts_key="$(tailscale_auth_key)"
  render_output="$(mktemp "${TMPDIR:-/tmp}/devbox-cloud-init.XXXXXX")"
  trap 'rm -f "$render_output"' EXIT

  if server_exists; then
    server_preexisted=1
  else
    server_preexisted=0
  fi

  render_cloud_init "$cidr" "$ts_key" "$render_output"
  validate_rendered_cloud_init "$render_output"
  ensure_firewall "$cidr"
  create_server_if_needed "$render_output"
  rm -f "$render_output"
  trap - EXIT

  public_ip="$(server_public_ip)"
  save_state "$cidr" "$public_ip" "${STATE_TAILSCALE_IP:-}"

  if (( server_preexisted )) && ssh_devbox 'true' >/dev/null 2>&1; then
    log "server exists; current SSH alias works"
  else
    write_ssh_include "$public_ip" "$public_ip"
    remove_known_hosts "$server_name" "$public_ip"
    wait_for_ssh "public bootstrap"
  fi

  wait_for_cloud_init

  tailscale_ip="$(wait_for_tailscale_ip)"
  save_state "$cidr" "$public_ip" "$tailscale_ip"
  write_ssh_include "$tailscale_ip" "$public_ip"
  remove_known_hosts "$server_name" "$tailscale_ip"
  wait_for_ssh "Tailscale"

  if [[ "${DEVBOX_SKIP_LOCKDOWN:-0}" != "1" ]]; then
    lockdown_impl "$cidr" "$public_ip"
  else
    warn "skipping public SSH lockdown because DEVBOX_SKIP_LOCKDOWN=1"
  fi

  if [[ "${DEVBOX_SKIP_CONVERGE:-0}" != "1" ]]; then
    cmd_converge
  else
    warn "skipping Ansible convergence because DEVBOX_SKIP_CONVERGE=1"
  fi

  if [[ "${DEVBOX_SKIP_DOCTOR:-0}" != "1" ]]; then
    cmd_doctor
  else
    warn "skipping doctor because DEVBOX_SKIP_DOCTOR=1"
  fi

  log "dev box ready: ssh $server_name"
}

cmd_converge() {
  load_state
  [[ -f "$ansible_inventory" ]] || die "missing Ansible inventory: $ansible_inventory"
  [[ -f "$ansible_converge_playbook" ]] || die "missing Ansible playbook: $ansible_converge_playbook"

  if [[ -z "${DEVBOX_BOOTSTRAP_SSH_CIDR:-}" && -n "${STATE_BOOTSTRAP_SSH_CIDR:-}" ]]; then
    export DEVBOX_BOOTSTRAP_SSH_CIDR="$STATE_BOOTSTRAP_SSH_CIDR"
  fi

  log "running Ansible convergence"
  run_ansible_playbook -i "$ansible_inventory" -u "$server_user" "$ansible_converge_playbook"
  ensure_server_github_key_registered
}

cmd_lockdown() {
  preflight_common
  preflight_hcloud
  load_state

  local cidr public_ip tailscale_ip
  cidr="$(lockdown_bootstrap_ssh_cidr)"

  public_ip="${STATE_PUBLIC_IP:-}"
  if [[ -z "$public_ip" ]] && server_exists; then
    public_ip="$(server_public_ip)"
  fi

  tailscale_ip="${STATE_TAILSCALE_IP:-}"
  if [[ -z "$tailscale_ip" ]] && ssh_devbox 'true' >/dev/null 2>&1; then
    tailscale_ip="$(ssh_devbox 'tailscale ip -4 2>/dev/null | head -n 1' || true)"
  fi

  if [[ -n "$tailscale_ip" ]]; then
    write_ssh_include "$tailscale_ip" "$public_ip"
    save_state "$cidr" "$public_ip" "$tailscale_ip"
  fi

  wait_for_ssh "current SSH config"
  lockdown_impl "$cidr" "$public_ip"
}

confirm_rebuild() {
  if [[ "${DEVBOX_CONFIRM_REBUILD:-}" == "$server_name" ]]; then
    return
  fi

  printf 'This will delete and recreate Hetzner server %s. Type %s to continue: ' "$server_name" "$server_name" >&2
  local answer
  read -r answer
  [[ "$answer" == "$server_name" ]] || die "rebuild cancelled"
}

wait_for_server_deleted() {
  local _attempt

  for _attempt in {1..60}; do
    if ! server_exists; then
      return
    fi
    sleep 3
  done

  die "server still exists after delete request"
}

cmd_rebuild() {
  preflight_render
  require_tailscale_auth_key
  preflight_hcloud_create
  confirm_rebuild

  if server_exists; then
    log "disabling delete/rebuild protection if present"
    hcloud_cmd server disable-protection "$server_name" delete rebuild || true
    log "deleting $server_name"
    hcloud_cmd server delete "$server_name"
    wait_for_server_deleted
  fi

  rm -f "$state_file"
  unset STATE_BOOTSTRAP_SSH_CIDR STATE_PUBLIC_IP STATE_TAILSCALE_IP
  cmd_up
}

doctor_pass() {
  printf 'pass  %-28s %s\n' "$1" "$2"
}

doctor_warn() {
  doctor_warnings=$((doctor_warnings + 1))
  printf 'warn  %-28s %s\n' "$1" "$2"
}

doctor_fail() {
  doctor_failures=$((doctor_failures + 1))
  printf 'fail  %-28s %s\n' "$1" "$2"
}

doctor_local_cmd() {
  local id="$1"
  local message="$2"
  local cmd="$3"
  local output

  if output="$(bash -o pipefail -lc "$cmd" 2>&1)"; then
    doctor_pass "$id" "${output:-$message}"
  else
    doctor_fail "$id" "${output:-failed: $message}"
  fi
}

doctor_remote_cmd() {
  local id="$1"
  local message="$2"
  local cmd="$3"
  local output

  if output="$(remote_user_sh "$cmd" 2>&1)"; then
    doctor_pass "$id" "${output:-$message}"
  else
    doctor_fail "$id" "${output:-failed: $message}"
  fi
}

doctor_remote_sudo_cmd() {
  local id="$1"
  local message="$2"
  local cmd="$3"
  local output

  if output="$(ssh_sudo bash -o pipefail -lc "$cmd" 2>&1)"; then
    doctor_pass "$id" "${output:-$message}"
  else
    doctor_fail "$id" "${output:-failed: $message}"
  fi
}

firewall_has_ingress() {
  local firewall_json="$1"
  local protocol="$2"
  local port="$3"
  local source="${4:-}"

  FIREWALL_JSON="$firewall_json" ruby -rjson -e '
    fw = JSON.parse(ENV.fetch("FIREWALL_JSON"))
    protocol, port, source = ARGV
    rules = fw["rules"] || fw["Rules"] || []
    found = rules.any? do |r|
      next false unless (r["direction"] || r["Direction"]) == "in"
      next false unless (r["protocol"] || r["Protocol"]).to_s == protocol
      next false unless (r["port"] || r["Port"]).to_s == port
      source.empty? || ((r["source_ips"] || r["SourceIPs"] || r["sourceIPs"] || []).include?(source))
    end
    exit(found ? 0 : 1)
  ' "$protocol" "$port" "$source"
}

doctor_hcloud() {
  if ! command -v hcloud >/dev/null 2>&1; then
    doctor_fail local.hcloud "hcloud missing"
    return
  fi
  doctor_pass local.hcloud "hcloud present"

  if ! server_exists; then
    doctor_fail hcloud.server "server does not exist: $server_name"
    return
  fi
  doctor_pass hcloud.server "server exists"

  local backup_window firewall_json
  backup_window="$(hcloud_cmd server describe "$server_name" -o 'format={{.BackupWindow}}' 2>/dev/null || true)"
  case "$backup_window" in
    ""|"<nil>"|"null"|"-")
      doctor_pass hcloud.backups "Hetzner paid backups not enabled"
      ;;
    *)
      doctor_fail hcloud.backups "Hetzner paid backups enabled: $backup_window"
      ;;
  esac

  if ! firewall_json="$(hcloud_cmd firewall describe "$firewall_name" -o json 2>/dev/null)"; then
    doctor_warn hcloud.firewall "could not inspect $firewall_name"
    return
  fi

  if firewall_has_ingress "$firewall_json" udp 41641 "0.0.0.0/0" &&
     firewall_has_ingress "$firewall_json" udp 41641 "::/0"; then
    doctor_pass hcloud.tailscale "UDP 41641 open for Tailscale direct connections"
  else
    doctor_warn hcloud.tailscale "UDP 41641 rule missing or incomplete"
  fi

  if firewall_has_ingress "$firewall_json" tcp 22 "0.0.0.0/0" ||
     firewall_has_ingress "$firewall_json" tcp 22 "::/0"; then
    doctor_fail hcloud.public-ssh "world-open SSH rule exists"
  elif firewall_has_ingress "$firewall_json" tcp 22; then
    doctor_fail hcloud.public-ssh "temporary SSH rule still exists"
  else
    doctor_pass hcloud.public-ssh "no public SSH ingress"
  fi

  if is_truthy "$public_web"; then
    if firewall_has_ingress "$firewall_json" tcp 80 "0.0.0.0/0" &&
       firewall_has_ingress "$firewall_json" tcp 443 "0.0.0.0/0"; then
      doctor_pass hcloud.public-web "public web enabled"
    else
      doctor_fail hcloud.public-web "DEVBOX_PUBLIC_WEB=1 but HTTP/HTTPS rules are missing"
    fi
  else
    if firewall_has_ingress "$firewall_json" tcp 80 ||
       firewall_has_ingress "$firewall_json" tcp 443; then
      doctor_fail hcloud.public-web "HTTP/HTTPS rules exist without DEVBOX_PUBLIC_WEB=1"
    else
      doctor_pass hcloud.public-web "no public web ingress"
    fi
  fi
}

doctor_remote() {
  if ! ssh_devbox 'true' >/dev/null 2>&1; then
    doctor_fail remote.ssh "ssh $server_name failed"
    return
  fi
  doctor_pass remote.ssh "ssh $server_name works"

  doctor_remote_sudo_cmd remote.cloud-init "cloud-init done" "cloud-init status --long | sed -n '1,3p'; cloud-init status --wait >/dev/null"
  doctor_remote_cmd remote.tailscale "Tailscale IPv4 present" "tailscale ip -4 | head -n 1 | grep -q '^100[.]' && tailscale ip -4 | head -n 1"
  doctor_remote_sudo_cmd remote.ufw "UFW active" "ufw status | grep -q '^Status: active' && ufw status | sed -n '1,8p'"
  doctor_remote_sudo_cmd remote.public-ssh "host public SSH closed" "! ufw status numbered | grep -Eq '22/tcp.*ALLOW IN'"
  doctor_remote_cmd remote.disk "root disk below 90%" "pct=\$(df -P / | awk 'NR==2 {gsub(/%/, \"\", \$5); print \$5}'); test \"\$pct\" -lt 90; printf '/ usage %s%%\\n' \"\$pct\""
  doctor_remote_cmd remote.tools "AI tools available" "codex --version && claude --version && gh --version | head -n 1"

  if is_truthy "$rootful_docker"; then
    doctor_remote_sudo_cmd docker.rootful "rootful Docker active" "systemctl is-active --quiet docker && docker info >/dev/null && docker compose version"
  else
    doctor_remote_cmd docker.rootless "rootless Docker active" "uid=\$(id -u); export XDG_RUNTIME_DIR=/run/user/\$uid DOCKER_HOST=unix:///run/user/\$uid/docker.sock; systemctl --user is-active --quiet docker && docker info >/dev/null && docker compose version"
    doctor_remote_sudo_cmd docker.rootful-off "rootful Docker inactive" "! systemctl is-active --quiet docker"
  fi
}

cmd_doctor() {
  [[ $# -eq 0 ]] || die "Usage: ./devbox doctor"
  preflight_common
  load_state
  doctor_failures=0
  doctor_warnings=0

  log "configuration"
  printf 'server: %s\n' "$server_name"
  printf 'hcloud context: %s\n' "$hcloud_context"
  printf 'firewall: %s\n' "$firewall_name"
  printf 'ssh include: %s\n' "$ssh_include"
  printf 'state file: %s\n' "$state_file"
  printf 'public web: %s\n' "$public_web"
  printf 'docker mode: %s\n' "$(is_truthy "$rootful_docker" && printf rootful || printf rootless)"

  if command -v ansible-playbook >/dev/null 2>&1 || command -v uvx >/dev/null 2>&1; then
    doctor_pass local.ansible "Ansible or uvx fallback present"
  else
    doctor_fail local.ansible "ansible-playbook missing and uvx fallback unavailable"
  fi

  doctor_local_cmd local.ssh-config "SSH alias resolves" "ssh -G '$server_name' >/dev/null"

  if [[ -f "$default_output" ]]; then
    if grep -Eq 'OPENSSH PRIVATE KEY|tskey-auth|__TAILSCALE_AUTH_KEY_B64__' "$default_output"; then
      doctor_fail local.rendered-cloud-init "stale secret-bearing $default_output exists"
    else
      doctor_warn local.rendered-cloud-init "stale $default_output exists"
    fi
  else
    doctor_pass local.rendered-cloud-init "no persistent rendered cloud-init"
  fi

  doctor_hcloud

  if [[ -f "$ssh_include" ]]; then
    local ssh_hostname
    ssh_hostname="$(ssh -G "$server_name" 2>/dev/null | awk '/^hostname / {print $2; exit}')"
    case "$ssh_hostname" in
      100.*) doctor_pass local.ssh-alias "points at Tailscale IPv4: $ssh_hostname" ;;
      *) doctor_warn local.ssh-alias "does not point at Tailscale IPv4: ${ssh_hostname:-unknown}" ;;
    esac
  else
    doctor_fail local.ssh-alias "SSH include missing: $ssh_include"
  fi

  doctor_remote

  if (( doctor_failures > 0 )); then
    printf 'doctor: fail (%d failure(s), %d warning(s))\n' "$doctor_failures" "$doctor_warnings" >&2
    return 1
  fi

  if (( doctor_warnings > 0 )); then
    printf 'doctor: warn (%d warning(s))\n' "$doctor_warnings" >&2
    return 0
  fi

  printf 'doctor: pass\n'
}

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    up) cmd_up "$@" ;;
    rebuild) cmd_rebuild "$@" ;;
    converge) cmd_converge "$@" ;;
    lockdown) cmd_lockdown "$@" ;;
    doctor) cmd_doctor "$@" ;;
    render) cmd_render "$@" ;;
    -h|--help|help|"") usage ;;
    *) usage >&2; die "unknown command: $command" ;;
  esac
}

main "$@"
